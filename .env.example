# PHASE2.5 部署密钥模板 —— 复制为 .env 并填写(镜像内不存任何密钥)
# 全部键与 config.yaml 一一对应,规则:前缀 MEMORY_AGENT_,嵌套用 __

# ---- L0 对话主力(OpenAI 兼容端点三元组;供应商与模型由人类指定) ----
MEMORY_AGENT_LLM__MODE=api
MEMORY_AGENT_LLM__CHAT__BASE_URL=
MEMORY_AGENT_LLM__CHAT__API_KEY=
MEMORY_AGENT_LLM__CHAT__MODEL=

# ---- L0 记忆抽取/整合专用(可与 chat 同端点;留空则回落 chat) ----
MEMORY_AGENT_LLM__MEMORY__BASE_URL=
MEMORY_AGENT_LLM__MEMORY__API_KEY=
MEMORY_AGENT_LLM__MEMORY__MODEL=

# ---- 备用端点(JSON 数组;主端点连续失败 N 次后自动切换) ----
# MEMORY_AGENT_LLM__CHAT__FALLBACKS=[{"base_url":"https://...","api_key":"...","model":"..."}]

# ---- L1 嵌入(Jina Embeddings API) ----
MEMORY_AGENT_EMBEDDER__BACKEND=jina_api
MEMORY_AGENT_EMBEDDER__JINA_API_KEY=
MEMORY_AGENT_EMBEDDER__MODEL_NAME=jinaai/jina-embeddings-v5-omni-small
MEMORY_AGENT_EMBEDDER__DIM=1024

# ---- 成本护栏 ----
MEMORY_AGENT_BUDGET__DAILY_USD=5.0

# ---- Qdrant(compose 内部域名,一般无需改) ----
MEMORY_AGENT_VECTORDB__MODE=server
MEMORY_AGENT_VECTORDB__URL=http://qdrant:6333
