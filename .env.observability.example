# M20 B:Langfuse 自托管栈密钥模板 —— 复制为 .env.observability 并填写(已 gitignore)。
# 仅 make observability-up 与 observability.enabled=true 时需要。

# ---- 自托管栈内部密钥(可自定,首启前设好即可) ----
POSTGRES_PASSWORD=postgres
CLICKHOUSE_PASSWORD=clickhouse
REDIS_PASSWORD=redis
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret

# ---- Langfuse 应用密钥(必填;NEXTAUTH_SECRET/SALT 用 `openssl rand -base64 32` 生成) ----
NEXTAUTH_SECRET=
LANGFUSE_SALT=
# ENCRYPTION_KEY 必须是 64 位十六进制:`openssl rand -hex 32`
LANGFUSE_ENCRYPTION_KEY=

# ---- 主应用侧:起栈后在 http://localhost:3000 建 project 取到,填入主 .env ----
# MEMORY_AGENT_OBSERVABILITY__ENABLED=true
# MEMORY_AGENT_OBSERVABILITY__PUBLIC_KEY=pk-lf-...
# MEMORY_AGENT_OBSERVABILITY__SECRET_KEY=sk-lf-...
# MEMORY_AGENT_OBSERVABILITY__OTLP_ENDPOINT=http://localhost:3000/api/public/otel/v1/traces
